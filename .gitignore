# ========================================
# 1. CLion 与 IDE 相关配置
# ========================================
.idea/
cmake-build-*/
*.swp
*~

# ========================================
# 2. 编译产物 (Build Output)
# 绝对不要把编译出来的二进制文件传进 Git
# ========================================
build/
Debug/
Release/
*.o
*.d
*.elf
*.bin
*.hex
*.map
*.lst
*.out

# ========================================
# 3. STM32CubeMX 相关备份文件
# ========================================
*.ioc.bak
*.bak
*.log
# 注：你的 .ioc 文件必须保留！它是工程配置的核心。
# Core 文件夹和 Drivers 文件夹也应当提交，保证别人拉取后能直接编译。

# ========================================
# 4. 操作系统生成的隐藏文件
# ========================================
.DS_Store
Thumbs.db

# ========================================
# 5. CMake 缓存文件（防止在根目录执行 cmake 产生）
# ========================================
CMakeCache.txt
CMakeFiles/